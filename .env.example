# PartyKit host. For local dev, partykit dev serves on localhost:1999.
# In production set this to your deployed PartyKit host, e.g. property-tycoon.<username>.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999

# Password for the /manage room-control console. This is a PartyKit-side secret
# (NOT exposed to the browser): set it on the deployed worker with
# `partykit env add ADMIN_PASSWORD`. Defaults to "monopoly-admin" for local dev
# (see party/auth.ts).
# ADMIN_PASSWORD=change-me

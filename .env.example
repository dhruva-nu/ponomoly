# Realtime Worker host. For local dev, `wrangler dev` serves on 127.0.0.1:8787.
# In production set this to your deployed Worker host, e.g.
# ponomoly.<your-subdomain>.workers.dev (or a custom domain / route).
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:8787

# Password for the /manage room-control console. This is a Worker-side secret
# (NOT exposed to the browser): set it on the deployed Worker with
# `wrangler secret put ADMIN_PASSWORD`. Defaults to "monopoly-admin" for local
# dev (see worker/auth.ts).
# ADMIN_PASSWORD=change-me
